# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=transactions
DB_PASSWORD=transactions
DB_NAME=transactions

# App
PORT=3000
NODE_ENV=development

# PrivatBank API
# Отримати на: https://acp.privatbank.ua/
# Формат: id:token  (наприклад: 123456:your_token_here)
PRIVATBANK_TOKEN=

# MCC auto-categorization (опційно)
# Залиш пустим — буде категорія 'other'

# JWT
JWT_ACCESS_SECRET=change_me_access_super_secret_key_32chars
JWT_REFRESH_SECRET=change_me_refresh_super_secret_key_32chars
